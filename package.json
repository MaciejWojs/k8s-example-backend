{
  "name": "app",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "bun run --hot src/index.ts",
    "minify": "bun run typecheck && bun build src/index.ts --target bun --outdir .dist --minify --sourcemap && bun run minify:seed",
    "minify:seed": "bun run typecheck && bun build src/infrastructure/db/seed.ts --target bun --outdir .dist --minify",
    "prod": "bun run --bun .dist/index.js",
    "migrate": "bun --bun drizzle-kit migrate",
    "generate": "bun --bun drizzle-kit generate",
    "push": "bun --bun drizzle-kit push",
    "reset": "bun run --bun src/infrastructure/db/reset-db.ts",
    "seed": "bun run --bun src/infrastructure/db/seed.ts || bun run --bun .dist/seed.js",
    "typecheck": "bunx --bun tsgo -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix"
  },
  "devDependencies": {
    "@0xts/gitleaks-cli": "^0.1.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/format": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "drizzle-seed": "1.0.0-rc.3-abc2ef6",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "prettier": "^3.9.6",
    "typescript-eslint": "^8.65.0"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "drizzle-kit": "1.0.0-rc.4-5d5b77c",
    "drizzle-orm": "1.0.0-rc.4-5d5b77c",
    "hono": "^4.12.31",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "package.json": "prettier --write"
  }
}
